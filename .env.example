# Copy to .env.local for local dev. Add the same keys in Vercel > Project >
# Settings > Environment Variables. These are client-side Firebase keys (safe to
# expose) — your real protection is Firestore Security Rules, not secrecy.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Calls: TURN relay (REQUIRED for reliable cross-network calls) ----------
# STUN (free, public) is always on, but it CANNOT connect peers on mobile data /
# symmetric NAT / CGNAT — those calls need a TURN relay. If "calls don't go
# through on different WiFi", this is almost always why.
#
# VITE_TURN_URL accepts a comma-separated list. Provide UDP + TCP + TLS for the
# same host so restrictive networks still connect, e.g.:
#   VITE_TURN_URL=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
# Get credentials from metered.ca, Twilio NTS, Cloudflare Calls, or self-host coturn.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
# Set to 'true' temporarily to force all media through TURN and verify it works.
VITE_TURN_FORCE_RELAY=
