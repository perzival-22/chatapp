// Reference Firestore Security Rules for QuickChat.
// Publish in Firebase Console → Firestore Database → Rules.
// Merge the `calls` block into your existing rules if you already have some.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users: anyone signed in can read profiles; you only edit your own ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Chats + messages: only participants ---
    match /chats/{chatId} {
      allow read, write: if request.auth != null
                         && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Only participants of the parent chat may read/write its messages.
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- Calls: WebRTC signaling. Only the two participants may touch a call ---
    match /calls/{callId} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.callerId;
      allow read, update, delete: if request.auth != null
                    && (request.auth.uid == resource.data.callerId
                        || request.auth.uid == resource.data.calleeId);

      match /{sub}/{candidateId} {
        // Only the two participants of the parent call may exchange candidates.
        allow read, write: if request.auth != null
          && (request.auth.uid ==
                get(/databases/$(database)/documents/calls/$(callId)).data.callerId
              || request.auth.uid ==
                get(/databases/$(database)/documents/calls/$(callId)).data.calleeId);
      }
    }
  }
}
